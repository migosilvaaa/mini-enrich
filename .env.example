# ZoomInfo API Credentials
# Set these in Vercel Dashboard → Settings → Environment Variables

# Option A: Username + Password (recommended — auto-generates JWT, refreshes automatically)
ZOOMINFO_USERNAME=your_zoominfo_username
ZOOMINFO_PASSWORD=your_zoominfo_password

# Option B: Static Bearer Token (easier for local testing, expires after 24 hours)
# Generate at: https://app.zoominfo.com/insights/developer/api-usage-token
# If this is set, it takes priority over username/password.
ZOOMINFO_BEARER_TOKEN=eyJ...
